{
  "name": "mant",
  "version": "0.3.0",
  "description": "A structured document query tool with a modern TUI for man pages",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "bun scripts/ci.ts",
    "ci": "bun run build",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/mantui/tsconfig.json",
    "rust:fmt": "cargo fmt --manifest-path engine/Cargo.toml --all --check",
    "rust:lint": "cargo clippy --manifest-path engine/Cargo.toml --workspace --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path engine/Cargo.toml --workspace",
    "build:mant": "bun scripts/build-mant.ts",
    "release:pack": "bun scripts/package-release.ts",
    "test": "bun test",
    "test:e2e": "bun test apps/mantui/tests/e2e"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.9.3"
  }
}
